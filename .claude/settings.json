{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(git *)",
      "Bash(python3 *)",
      "Bash(pwsh *)"
    ]
  },
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "env": {}
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {}
    }
  }
}
